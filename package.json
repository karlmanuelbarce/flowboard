{
  "name": "flowboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "docker compose up --build -d",
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "logs": "docker compose logs -f",
    "test": "npm --prefix api test",
    "test:coverage": "npm --prefix api run test:coverage",
    "db:audit-logs": "docker exec flowboard-db psql -U postgres -d flowboard -c 'SELECT * FROM \"AuditLog\" ORDER BY \"createdAt\" DESC LIMIT 10;'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karlmanuelbarce/flowboard.git"
  }
}
